datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── IDENTITY & SECURITY ENUMS ─────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum TokenStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum LoginStatus {
  SUCCESS
  FAILED_INVALID_CREDENTIALS
  FAILED_ACCOUNT_LOCKED
  FAILED_UNVERIFIED_EMAIL
  FAILED_SUSPENDED
}

enum Role {
  SUPER_ADMIN
  UNIVERSITY_ADMIN
  HOD
  FACULTY
  STUDENT
  ACCOUNTANT
  LIBRARIAN
  EXAM_CONTROLLER
  PLACEMENT_OFFICER
  HOSTEL_ADMIN
  PARENT
}

enum ExamType {
  MID_SEMESTER
  END_SEMESTER
  QUIZ
  ASSIGNMENT
  LAB_EXAM
  PRACTICAL
  VIVA
  PROJECT_EVALUATION
  RETEST
  SUPPLEMENTARY
}

enum ApprovalStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  LOCKED
}

enum ResultStatus {
  PROMOTED
  BACKLOG
  DETAINED
  GRADUATED
  ELIGIBLE_FOR_GRADUATION
  PROCESSING
}

enum ReEvalStatus {
  REQUESTED
  IN_REVIEW
  COMPLETED
  REJECTED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  MEDICAL_LEAVE
  OFFICIAL_LEAVE
  HOLIDAY
  CANCELLED
  EXCUSED
}

// ─── CORE TENANCY MODEL ───────────────────────────────────────────────

model University {
  id        String    @id @default(uuid())
  name      String    @unique
  domain    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users     User[]
  roles     RoleEntity[]
}

// ─── PURE IDENTITY MODEL ──────────────────────────────────────────────

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  status              UserStatus           @default(PENDING_VERIFICATION)
  role                Role                 @default(STUDENT) // Backward compatibility default
  isVerified          Boolean              @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  universityId        String?
  university          University?          @relation(fields: [universityId], references: [id], onDelete: SetNull)

  // Identity Subsystem Relations
  userRoles           UserRole[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  passwordResets      PasswordReset[]
  emailVerifications  EmailVerification[]
  devices             Device[]
  auditLogs           AuditLog[]
  apiKeys             ApiKey[]
  loginAttempts       LoginAttempt[]

  // Domain Module Relations (Loose Coupling via Identity ID)
  student             Student?
  faculty             Faculty?
  notifications       Notification[]
  aiConversations     AIConversation[]

  @@index([email])
  @@index([universityId])
  @@index([status])
  @@index([role])
  @@index([createdAt])
}

// ─── RBAC ROLE & PERMISSION SYSTEM ────────────────────────────────────

model RoleEntity {
  id           String           @id @default(uuid())
  code         String           @unique // e.g. "FACULTY_HEAD"
  name         String           // e.g. "Head of Faculty"
  description  String?
  isSystem     Boolean          @default(false)
  universityId String?
  university   University?      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  userRoles    UserRole[]
  permissions  RolePermission[]

  @@index([code])
  @@index([universityId])
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique // e.g. "attendance:session:create"
  name        String
  resource    String           // e.g. "attendance"
  action      String           // e.g. "create"
  description String?
  createdAt   DateTime         @default(now())

  roles       RolePermission[]

  @@index([code])
  @@index([resource, action])
}

model RolePermission {
  roleId       String
  role         RoleEntity @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  role       RoleEntity @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime   @default(now())

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ─── SESSION & TOKEN MANAGEMENT ──────────────────────────────────────

model Session {
  id             String        @id @default(uuid())
  refreshToken   String?       @unique
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId       String?
  device         Device?       @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  status         SessionStatus @default(ACTIVE)
  ipAddress      String?
  userAgent      String?
  lastActivityAt DateTime      @default(now())
  expiresAt      DateTime
  createdAt      DateTime      @default(now())

  refreshTokens  RefreshToken[]

  @@index([userId])
  @@index([refreshToken])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
  @@index([status, expiresAt])
}

model RefreshToken {
  id              String      @id @default(uuid())
  sessionId       String
  session         Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash       String      @unique
  status          TokenStatus @default(ACTIVE)
  replacedByToken String?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  revokedAt       DateTime?

  @@index([tokenHash])
  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([replacedByToken])
  @@index([userId, status])
}

model PasswordReset {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String      @unique
  status    TokenStatus @default(ACTIVE)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime    @default(now())

  @@index([token])
  @@index([userId])
  @@index([status])
}

model EmailVerification {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String      @unique
  status    TokenStatus @default(ACTIVE)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime    @default(now())

  @@index([token])
  @@index([userId])
  @@index([status])
}

// ─── DEVICE & SECURITY AUDITING ───────────────────────────────────────

model Device {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName  String?   // e.g. "MacBook Pro"
  browser     String?   // e.g. "Chrome 122"
  os          String?   // e.g. "macOS Sonoma"
  ipAddress   String?
  location    String?   // Country / City placeholder
  isTrusted   Boolean   @default(false)
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  sessions    Session[]

  @@index([userId])
  @@index([userId, isTrusted])
}

model LoginAttempt {
  id            String      @id @default(uuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  ipAddress     String?
  userAgent     String?
  status        LoginStatus
  failureReason String?
  createdAt     DateTime    @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([status])
  @@index([createdAt])
  @@index([email, createdAt])
  @@index([ipAddress, status, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorId    String?  // ID of admin who performed action (if different)
  action     String   // e.g. "PASSWORD_RESET", "ROLE_UPDATED"
  resource   String?  // e.g. "user", "course"
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, action])
  @@index([action, createdAt])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  key        String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?

  @@index([userId])
  @@index([key])
}

// ─── FUTURE SAAS EXPANSION PLACEHOLDERS ───────────────────────────────

model TenantSubscription {
  id           String   @id @default(uuid())
  universityId String   @unique
  planName     String   @default("ENTERPRISE_TIER_1")
  maxUsers     Int      @default(10000)
  status       String   @default("ACTIVE")
  renewsAt     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([universityId])
}

model AIUsageToken {
  id        String   @id @default(uuid())
  userId    String
  tokensUsed Int     @default(0)
  promptCount Int    @default(0)
  monthYear String   // e.g. "2026-07"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, monthYear])
}

// ─── DOMAIN MODULES (STUDENT, FACULTY, ACADEMICS) ──────────────────────

model Student {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id])
  rollNo           String       @unique
  enrollmentNo     String?      @unique
  registrationNo   String?      @unique
  name             String
  branch           String
  semester         String
  academicYear     String
  status           String       @default("Active")
  admissionDate    DateTime     @default(now())
  category         String       @default("General")
  scholarship      String       @default("None")
  transport        Boolean      @default(false)
  photoUrl         String?
  parentName       String?
  parentContact    String?

  guardianDetails  Json?
  emergencyContact Json?
  medicalInfo      Json?
  nationality      String?      @default("Indian")
  address          Json?
  documents        Json?
  timeline         Json?
  analytics        Json?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  attendance       Attendance[]
  results          Result[]
  hostelRoom       HostelRoom?
  libraryIssues    LibraryIssue[]
  fees             FeeReceipt[]
  predictions      AttendancePrediction[]
  enrollments      Enrollment[]
  examMarks        ExamMark[]
  resultSummaries  StudentResultSummary[]
  reEvaluations    ReEvaluation[]

  @@index([rollNo])
  @@index([enrollmentNo])
  @@index([registrationNo])
  @@index([userId])
  @@index([branch, semester])
  @@index([status])
}

model Faculty {
  id              String      @id @default(uuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  employeeId      String?     @unique
  name            String
  department      String
  designation     String      @default("Assistant Professor")
  joiningDate     DateTime    @default(now())
  qualification   String      @default("PhD")
  experienceYears Int         @default(0)
  status          String      @default("Active")
  specialty       String?
  researchArea    String?

  officeInfo      Json?
  researchModule  Json?
  workload        Json?
  leaveManagement Json?
  performance     Json?
  documents       Json?
  timeline        Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  subjects        Subject[]
  schedules       Timetable[]
  facultyAttendance  FacultyAttendance[]
  attendanceSessions AttendanceSession[]
  offeredCourses  CourseOffering[]

  @@index([userId])
  @@index([employeeId])
  @@index([department])
  @@index([status])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  credits   Int       @default(3)
  semester  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  subjects  Subject[]
}

model Subject {
  id              String      @id @default(uuid())
  code            String      @unique
  name            String
  courseId        String
  course          Course      @relation(fields: [courseId], references: [id])
  facultyId       String?
  faculty         Faculty?    @relation(fields: [facultyId], references: [id])
  type            String      @default("CORE")
  
  prerequisites   Json?
  corequisites    Json?
  syllabusDetails Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  attendance        Attendance[]
  timetables        Timetable[]
  attendanceSessions AttendanceSession[]
  predictions       AttendancePrediction[]
  offerings         CourseOffering[]
  exams             Exam[]
  assessmentComponent AssessmentComponent?

  @@index([courseId])
  @@index([facultyId])
  @@index([type])
}

model Attendance {
  id           String            @id @default(uuid())
  date         DateTime
  status       AttendanceStatus  @default(PRESENT)
  studentId    String
  student      Student           @relation(fields: [studentId], references: [id])
  subjectId    String
  subject      Subject           @relation(fields: [subjectId], references: [id])
  sessionId    String?
  session      AttendanceSession? @relation(fields: [sessionId], references: [id])
  method       String            @default("Manual")
  remarks      String?
  metadata     Json?
  riskLevel    String            @default("Low")
  examEligible Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([studentId, subjectId, date])
  @@index([sessionId])
  @@index([date])
  @@index([status])
}

model AttendancePrediction {
  id                    String   @id @default(uuid())
  studentId             String
  student               Student  @relation(fields: [studentId], references: [id])
  subjectId             String
  subject               Subject  @relation(fields: [subjectId], references: [id])
  predictedAttendanceRate Float
  shortageRisk          String
  examEligible          Boolean  @default(true)
  confidenceScore       Float
  recommendations       Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([shortageRisk])
}

model AttendanceSession {
  id         String       @id @default(uuid())
  subjectId  String
  subject    Subject      @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    Faculty      @relation(fields: [facultyId], references: [id])
  section    String
  semester   String
  classroom  String?
  date       DateTime     @default(now())
  startTime  String
  endTime    String
  status     String       @default("Active")
  method     String       @default("Manual")
  qrCode     String?
  location   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  attendance Attendance[]

  @@index([subjectId])
  @@index([facultyId])
  @@index([date])
}

model FacultyAttendance {
  id           String    @id @default(uuid())
  facultyId    String
  faculty      Faculty   @relation(fields: [facultyId], references: [id])
  date         DateTime  @default(now())
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Float?
  status       String    @default("Present")
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([facultyId])
  @@index([date])
}

model Timetable {
  id         String   @id @default(uuid())
  dayOfWeek  Int
  startTime  String
  endTime    String
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    Faculty  @relation(fields: [facultyId], references: [id])

  @@index([subjectId])
  @@index([facultyId])
}

model AssessmentComponent {
  id               String   @id @default(uuid())
  subjectId        String   @unique
  subject          Subject  @relation(fields: [subjectId], references: [id])
  universityId     String?

  internalWeight   Float    @default(30)
  externalWeight   Float    @default(70)
  assignmentWeight Float    @default(0)
  quizWeight       Float    @default(0)
  labWeight        Float    @default(0)
  attendanceWeight Float    @default(0)
  projectWeight    Float    @default(0)
  presentationWeight Float  @default(0)

  internalMaxMarks   Float  @default(30)
  externalMaxMarks   Float  @default(70)
  totalMaxMarks      Float  @default(100)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([subjectId])
  @@index([universityId])
}

model Exam {
  id               String        @id @default(uuid())
  title            String
  examType         ExamType      @default(MID_SEMESTER)
  subjectId        String
  subject          Subject       @relation(fields: [subjectId], references: [id])
  universityId     String?
  semester         String
  academicYear     String

  date             DateTime
  startTime        String
  endTime          String

  classroomId      String?
  invigilatorId    String?
  venueDetails     Json?

  maxMarks         Float         @default(100)
  passingMarks     Float         @default(40)
  weightagePercent Float         @default(100)
  duration         Int           @default(180)

  approvalStatus   ApprovalStatus @default(PENDING)
  isLocked         Boolean       @default(false)
  lockedAt         DateTime?
  lockedById       String?

  questionBlueprintMetadata  Json?
  difficultyLevel  String?   @default("MEDIUM")
  conflictHash     String?

  createdById      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  marks            ExamMark[]
  reEvaluations    ReEvaluation[]
  auditLogs        ExamAuditLog[]

  @@index([subjectId])
  @@index([universityId])
  @@index([examType])
  @@index([semester, academicYear])
  @@index([date])
  @@index([approvalStatus])
  @@index([conflictHash])
  @@index([classroomId, date, startTime])
}

model ExamMark {
  id               String        @id @default(uuid())
  examId           String
  exam             Exam          @relation(fields: [examId], references: [id])
  studentId        String
  student          Student       @relation(fields: [studentId], references: [id])

  internalMarks    Float         @default(0)
  externalMarks    Float         @default(0)
  assignmentMarks  Float         @default(0)
  quizMarks        Float         @default(0)
  labMarks         Float         @default(0)
  projectMarks     Float         @default(0)
  presentationMarks Float        @default(0)
  attendanceMarks  Float         @default(0)
  totalMarks       Float         @default(0)

  grade            String?
  gradePoint       Float?
  creditPoints     Float?

  originalMarks    Float?
  moderatedMarks   Float?
  moderationDelta  Float?
  moderationReason String?

  approvalStatus   ApprovalStatus @default(PENDING)
  submittedById    String?
  submittedAt      DateTime?
  reviewedById     String?
  reviewedAt       DateTime?
  approvedById     String?
  approvedAt       DateTime?
  rejectionReason  String?

  hasReEvalRequest Boolean       @default(false)
  auditTrail       Json?
  performanceMetadata Json?

  isLocked         Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  reEvaluations    ReEvaluation[]

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([examId, studentId])
  @@index([approvalStatus])
  @@index([grade])
  @@index([studentId, grade])
}

model GradingPolicy {
  id                    String   @id @default(uuid())
  universityId          String?  @unique

  gradeBoundaries       Json?
  gradePoints           Json?

  creditSystem          String   @default("10_POINT")
  promotionMinCGPA      Float    @default(4.0)
  promotionMaxBacklogs  Int      @default(3)
  graduationMinCredits  Int      @default(120)
  graduationMinCGPA     Float    @default(5.0)
  passingGradePoint     Float    @default(4.0)

  customRules           Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([universityId])
}

model StudentResultSummary {
  id                String       @id @default(uuid())
  studentId         String
  student           Student      @relation(fields: [studentId], references: [id])
  universityId      String?
  semester          String
  academicYear      String

  sgpa              Float        @default(0.0)
  cgpa              Float        @default(0.0)

  creditsRegistered Int          @default(0)
  creditsEarned     Int          @default(0)
  totalCreditPoints Float        @default(0.0)

  backlogsCount     Int          @default(0)
  backlogSubjects   Json?

  resultStatus      ResultStatus @default(PROCESSING)
  isEligibleForPromotion Boolean @default(false)
  isEligibleForGraduation Boolean @default(false)

  processedAt       DateTime?
  processedById     String?
  aiInsights        Json?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([studentId, semester, academicYear])
  @@index([studentId])
  @@index([universityId])
  @@index([semester, academicYear])
  @@index([resultStatus])
  @@index([cgpa])
  @@index([studentId, semester])
}

model ExamAuditLog {
  id           String   @id @default(uuid())
  examId       String?
  exam         Exam?    @relation(fields: [examId], references: [id])
  examMarkId   String?
  action       String
  actorId      String
  actorRole    String
  previousValue Json?
  newValue      Json?
  ipAddress    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([examId])
  @@index([examMarkId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model ReEvaluation {
  id            String        @id @default(uuid())
  examId        String
  exam          Exam          @relation(fields: [examId], references: [id])
  examMarkId    String?
  examMark      ExamMark?     @relation(fields: [examMarkId], references: [id])
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])

  status        ReEvalStatus  @default(REQUESTED)
  reason        String
  requestedAt   DateTime      @default(now())

  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?

  previousMarks Float?
  revisedMarks  Float?
  previousGrade String?
  revisedGrade  String?

  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([examId])
  @@index([studentId])
  @@index([status])
  @@index([examMarkId])
}

model ResultProcessingJob {
  id            String   @id @default(uuid())
  universityId  String?
  semester      String
  academicYear  String
  batchFilter   Json?

  status        String   @default("QUEUED")
  totalStudents Int      @default(0)
  processed     Int      @default(0)
  failed        Int      @default(0)
  errorLog      Json?

  triggeredById String
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([universityId])
  @@index([semester, academicYear])
  @@index([status])
}

model Result {
  id         String   @id @default(uuid())
  marks      Float
  grade      String
  examType   String
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model HostelRoom {
  id        String   @id @default(uuid())
  roomNo    String
  block     String
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model LibraryIssue {
  id         String    @id @default(uuid())
  bookTitle  String
  issueDate  DateTime  @default(now())
  returnDate DateTime?
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model FeeReceipt {
  id        String   @id @default(uuid())
  amount    Float
  status    String
  dueDate   DateTime
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  history   Json
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id           String   @id @default(uuid())
  title        String
  content      String
  type         String
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Program {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  durationYears Int      @default(4)
  departmentId  String?
  universityId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([universityId])
}

model Classroom {
  id            String           @id @default(uuid())
  building      String
  roomNo        String
  capacity      Int
  type          String           @default("Classroom")
  resources     Json?
  availability  Boolean          @default(true)
  universityId  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  offerings     CourseOffering[]

  @@index([universityId])
  @@index([building, roomNo])
}

model CourseOffering {
  id           String      @id @default(uuid())
  subjectId    String
  subject      Subject     @relation(fields: [subjectId], references: [id])
  facultyId    String?
  faculty      Faculty?    @relation(fields: [facultyId], references: [id])
  classroomId  String?
  classroom    Classroom?  @relation(fields: [classroomId], references: [id])
  section      String
  semester     String
  academicYear String
  maxCapacity  Int         @default(60)
  status       String      @default("Open")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  enrollments  Enrollment[]

  @@index([subjectId])
  @@index([facultyId])
  @@index([classroomId])
}

model Enrollment {
  id         String         @id @default(uuid())
  studentId  String
  student    Student        @relation(fields: [studentId], references: [id])
  offeringId String
  offering   CourseOffering @relation(fields: [offeringId], references: [id])
  status     String         @default("ENROLLED")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([studentId])
  @@index([offeringId])
}

model AcademicCalendar {
  id           String   @id @default(uuid())
  title        String
  type         String
  startDate    DateTime
  endDate      DateTime
  description  String?
  universityId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([universityId])
  @@index([startDate])
}
