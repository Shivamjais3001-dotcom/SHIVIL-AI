datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  UNIVERSITY_ADMIN
  HOD
  FACULTY
  STUDENT
  ACCOUNTANT
  LIBRARIAN
  EXAM_CONTROLLER
  PLACEMENT_OFFICER
  HOSTEL_ADMIN
  PARENT
}

enum ExamType {
  MID_SEMESTER
  END_SEMESTER
  QUIZ
  ASSIGNMENT
  LAB_EXAM
  PRACTICAL
  VIVA
  PROJECT_EVALUATION
  RETEST
  SUPPLEMENTARY
}

enum ApprovalStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  LOCKED
}

enum ResultStatus {
  PROMOTED
  BACKLOG
  DETAINED
  GRADUATED
  ELIGIBLE_FOR_GRADUATION
  PROCESSING
}

enum ReEvalStatus {
  REQUESTED
  IN_REVIEW
  COMPLETED
  REJECTED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  MEDICAL_LEAVE
  OFFICIAL_LEAVE
  HOLIDAY
  CANCELLED
  EXCUSED
}

model University {
  id        String    @id @default(uuid())
  name      String    @unique
  domain    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users     User[]
}

model User {
  id                        String              @id @default(uuid())
  email                     String              @unique
  passwordHash              String
  role                      Role                @default(STUDENT)
  isVerified                Boolean             @default(false)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  deletedAt                 DateTime?
  
  universityId              String?
  university                University?         @relation(fields: [universityId], references: [id], onDelete: SetNull)

  student                   Student?
  faculty                   Faculty?
  notifications             Notification[]
  sessions                  Session[]
  auditLogs                 AuditLog[]
  aiConversations           AIConversation[]
  passwordResets            PasswordReset[]
  emailVerifications        EmailVerification[]
  apiKeys                   ApiKey[]

  @@index([email])
  @@index([universityId])
}

model Student {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id])
  rollNo           String       @unique
  enrollmentNo     String?      @unique
  registrationNo   String?      @unique
  name             String
  branch           String
  semester         String
  academicYear     String
  status           String       @default("Active")
  admissionDate    DateTime     @default(now())
  category         String       @default("General")
  scholarship      String       @default("None")
  transport        Boolean      @default(false)
  photoUrl         String?
  parentName       String?
  parentContact    String?

  // Structured JSON fields for Enterprise scale and AI compatibility
  guardianDetails  Json?
  emergencyContact Json?
  medicalInfo      Json?
  nationality      String?      @default("Indian")
  address          Json?
  documents        Json?
  timeline         Json?
  analytics        Json?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  attendance       Attendance[]
  results          Result[]
  hostelRoom       HostelRoom?
  libraryIssues    LibraryIssue[]
  fees             FeeReceipt[]
  predictions      AttendancePrediction[]
  enrollments      Enrollment[]
  examMarks        ExamMark[]
  resultSummaries  StudentResultSummary[]
  reEvaluations    ReEvaluation[]

  @@index([rollNo])
  @@index([enrollmentNo])
  @@index([registrationNo])
  @@index([userId])
  @@index([branch, semester])
  @@index([status])
}

model Faculty {
  id              String      @id @default(uuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  employeeId      String?     @unique
  name            String
  department      String
  designation     String      @default("Assistant Professor")
  joiningDate     DateTime    @default(now())
  qualification   String      @default("PhD")
  experienceYears Int         @default(0)
  status          String      @default("Active")
  specialty       String?     // Keep for backward compatibility
  researchArea    String?

  // Structured JSON fields for workload, leaves, research, and timelines
  officeInfo      Json?
  researchModule  Json?
  workload        Json?
  leaveManagement Json?
  performance     Json?
  documents       Json?
  timeline        Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  subjects        Subject[]
  schedules       Timetable[]
  facultyAttendance  FacultyAttendance[]
  attendanceSessions AttendanceSession[]
  offeredCourses  CourseOffering[]

  @@index([userId])
  @@index([employeeId])
  @@index([department])
  @@index([status])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  credits   Int       @default(3)
  semester  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  subjects  Subject[]
}

model Subject {
  id              String      @id @default(uuid())
  code            String      @unique
  name            String
  courseId        String
  course          Course      @relation(fields: [courseId], references: [id])
  facultyId       String?
  faculty         Faculty?    @relation(fields: [facultyId], references: [id])
  type            String      @default("CORE") // CORE, ELECTIVE
  
  // Curriculum configuration JSONs for advanced mapping and version control
  prerequisites   Json?
  corequisites    Json?
  syllabusDetails Json? // { theoryCredits, practicalCredits, outcomes, version }

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  attendance        Attendance[]
  timetables        Timetable[]
  attendanceSessions AttendanceSession[]
  predictions       AttendancePrediction[]
  offerings         CourseOffering[]
  exams             Exam[]
  assessmentComponent AssessmentComponent?

  @@index([courseId])
  @@index([facultyId])
  @@index([type])
}

model Attendance {
  id           String            @id @default(uuid())
  date         DateTime
  status       AttendanceStatus  @default(PRESENT)
  studentId    String
  student      Student           @relation(fields: [studentId], references: [id])
  subjectId    String
  subject      Subject           @relation(fields: [subjectId], references: [id])
  sessionId    String?
  session      AttendanceSession? @relation(fields: [sessionId], references: [id])
  method       String            @default("Manual")
  remarks      String?
  metadata     Json?
  riskLevel    String            @default("Low")
  examEligible Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([studentId, subjectId, date])
  @@index([sessionId])
  @@index([date])
  @@index([status])
}

model AttendancePrediction {
  id                    String   @id @default(uuid())
  studentId             String
  student               Student  @relation(fields: [studentId], references: [id])
  subjectId             String
  subject               Subject  @relation(fields: [subjectId], references: [id])
  predictedAttendanceRate Float
  shortageRisk          String
  examEligible          Boolean  @default(true)
  confidenceScore       Float
  recommendations       Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([shortageRisk])
}

model AttendanceSession {
  id         String       @id @default(uuid())
  subjectId  String
  subject    Subject      @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    Faculty      @relation(fields: [facultyId], references: [id])
  section    String
  semester   String
  classroom  String?
  date       DateTime     @default(now())
  startTime  String
  endTime    String
  status     String       @default("Active")
  method     String       @default("Manual")
  qrCode     String?
  location   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  attendance Attendance[]

  @@index([subjectId])
  @@index([facultyId])
  @@index([date])
}

model FacultyAttendance {
  id           String    @id @default(uuid())
  facultyId    String
  faculty      Faculty   @relation(fields: [facultyId], references: [id])
  date         DateTime  @default(now())
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Float?
  status       String    @default("Present")
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([facultyId])
  @@index([date])
}

model Timetable {
  id         String   @id @default(uuid())
  dayOfWeek  Int      // 1 = Monday, etc.
  startTime  String   // e.g. "09:00"
  endTime    String   // e.g. "10:30"
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    Faculty  @relation(fields: [facultyId], references: [id])

  @@index([subjectId])
  @@index([facultyId])
}


// ============================================================
// EXAMINATION & ASSESSMENT ENGINE — Sprint 8
// ============================================================

// Assessment Component Configuration — per-subject weightage
model AssessmentComponent {
  id               String   @id @default(uuid())
  subjectId        String   @unique
  subject          Subject  @relation(fields: [subjectId], references: [id])
  universityId     String?

  // Weightage breakdown (must sum to 100%)
  internalWeight   Float    @default(30)   // Internal assessment %
  externalWeight   Float    @default(70)   // End-semester exam %
  assignmentWeight Float    @default(0)    // Assignments %
  quizWeight       Float    @default(0)    // Quizzes %
  labWeight        Float    @default(0)    // Lab practical %
  attendanceWeight Float    @default(0)    // Attendance-linked marks %
  projectWeight    Float    @default(0)    // Project %
  presentationWeight Float  @default(0)   // Presentation / Viva %

  // Max marks per component
  internalMaxMarks   Float  @default(30)
  externalMaxMarks   Float  @default(70)
  totalMaxMarks      Float  @default(100)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([subjectId])
  @@index([universityId])
}

// Core Exam Entity
model Exam {
  id               String        @id @default(uuid())
  title            String
  examType         ExamType      @default(MID_SEMESTER)
  subjectId        String
  subject          Subject       @relation(fields: [subjectId], references: [id])
  universityId     String?
  semester         String
  academicYear     String

  // Scheduling
  date             DateTime
  startTime        String        // HH:MM
  endTime          String        // HH:MM

  // Venue & Invigilation
  classroomId      String?
  invigilatorId    String?       // Faculty ID
  venueDetails     Json?         // Additional room info

  // Exam Configuration
  maxMarks         Float         @default(100)
  passingMarks     Float         @default(40)
  weightagePercent Float         @default(100)
  duration         Int           @default(180) // minutes

  // Status & Workflow
  approvalStatus   ApprovalStatus @default(PENDING)
  isLocked         Boolean       @default(false)
  lockedAt         DateTime?
  lockedById       String?

  // AI Metadata
  questionBlueprintMetadata  Json?   // AI question paper blueprint data
  difficultyLevel  String?   @default("MEDIUM")

  // Conflict detection hash: date+startTime+classroomId
  conflictHash     String?

  createdById      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  marks            ExamMark[]
  reEvaluations    ReEvaluation[]
  auditLogs        ExamAuditLog[]

  @@index([subjectId])
  @@index([universityId])
  @@index([examType])
  @@index([semester, academicYear])
  @@index([date])
  @@index([approvalStatus])
  @@index([conflictHash])
  @@index([classroomId, date, startTime]) // Conflict detection composite
}

// ExamMark — Core mark record with full audit trail
model ExamMark {
  id               String        @id @default(uuid())
  examId           String
  exam             Exam          @relation(fields: [examId], references: [id])
  studentId        String
  student          Student       @relation(fields: [studentId], references: [id])

  // Component-wise marks
  internalMarks    Float         @default(0)
  externalMarks    Float         @default(0)
  assignmentMarks  Float         @default(0)
  quizMarks        Float         @default(0)
  labMarks         Float         @default(0)
  projectMarks     Float         @default(0)
  presentationMarks Float        @default(0)
  attendanceMarks  Float         @default(0)
  totalMarks       Float         @default(0)

  // Grading
  grade            String?       // A+, A, B+, B, C, D, F
  gradePoint       Float?        // 10.0, 9.0, 8.0 etc.
  creditPoints     Float?        // gradePoint * credits

  // Moderation
  originalMarks    Float?        // Before moderation
  moderatedMarks   Float?        // After moderation delta
  moderationDelta  Float?        // e.g. +5, -2
  moderationReason String?

  // Approval workflow
  approvalStatus   ApprovalStatus @default(PENDING)
  submittedById    String?       // Faculty who entered marks
  submittedAt      DateTime?
  reviewedById     String?       // HOD who reviewed
  reviewedAt       DateTime?
  approvedById     String?       // EXAM_CONTROLLER who approved
  approvedAt       DateTime?
  rejectionReason  String?

  // Re-evaluation flag
  hasReEvalRequest Boolean       @default(false)

  // Full immutable audit trail (JSON array of changes)
  auditTrail       Json?

  // AI metadata
  performanceMetadata Json?      // AI anomaly detection flags

  isLocked         Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  reEvaluations    ReEvaluation[]

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([examId, studentId])
  @@index([approvalStatus])
  @@index([grade])
  @@index([studentId, grade])
}

// GradingPolicy — Per-university, multi-tenant grading rules
model GradingPolicy {
  id                    String   @id @default(uuid())
  universityId          String?  @unique

  // Letter grade boundaries (percentage thresholds)
  // e.g. { "O": 90, "A+": 80, "A": 70, "B+": 60, "B": 50, "C": 45, "P": 40, "F": 0 }
  gradeBoundaries       Json?

  // Grade points per letter
  // e.g. { "O": 10, "A+": 9, "A": 8, "B+": 7, "B": 6, "C": 5, "P": 4, "F": 0 }
  gradePoints           Json?

  // CGPA/SGPA rules
  creditSystem          String   @default("10_POINT")  // 10_POINT, 4_POINT, PERCENTAGE
  promotionMinCGPA      Float    @default(4.0)
  promotionMaxBacklogs  Int      @default(3)
  graduationMinCredits  Int      @default(120)
  graduationMinCGPA     Float    @default(5.0)
  passingGradePoint     Float    @default(4.0)

  // Custom university rules JSON (for any edge cases)
  customRules           Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([universityId])
}

// StudentResultSummary — Computed SGPA/CGPA per semester
model StudentResultSummary {
  id                String       @id @default(uuid())
  studentId         String
  student           Student      @relation(fields: [studentId], references: [id])
  universityId      String?
  semester          String
  academicYear      String

  // Computed scores
  sgpa              Float        @default(0.0)
  cgpa              Float        @default(0.0)

  // Credits
  creditsRegistered Int          @default(0)
  creditsEarned     Int          @default(0)
  totalCreditPoints Float        @default(0.0)

  // Backlogs
  backlogsCount     Int          @default(0)
  backlogSubjects   Json?        // Array of {subjectId, subjectCode, marks, grade}

  // Promotion & Status
  resultStatus      ResultStatus @default(PROCESSING)
  isEligibleForPromotion Boolean @default(false)
  isEligibleForGraduation Boolean @default(false)

  // Processing metadata
  processedAt       DateTime?
  processedById     String?

  // AI Insights
  aiInsights        Json?        // Performance trend, risk prediction

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([studentId, semester, academicYear])
  @@index([studentId])
  @@index([universityId])
  @@index([semester, academicYear])
  @@index([resultStatus])
  @@index([cgpa])
  @@index([studentId, semester])
}

// ExamAuditLog — Immutable audit trail for all exam operations
model ExamAuditLog {
  id           String   @id @default(uuid())
  examId       String?
  exam         Exam?    @relation(fields: [examId], references: [id])
  examMarkId   String?
  action       String   // e.g. MARKS_ENTERED, MARKS_MODERATED, MARKS_APPROVED, EXAM_LOCKED
  actorId      String
  actorRole    String
  previousValue Json?
  newValue      Json?
  ipAddress    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([examId])
  @@index([examMarkId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ReEvaluation — Student/faculty re-evaluation requests
model ReEvaluation {
  id            String        @id @default(uuid())
  examId        String
  exam          Exam          @relation(fields: [examId], references: [id])
  examMarkId    String?
  examMark      ExamMark?     @relation(fields: [examMarkId], references: [id])
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])

  status        ReEvalStatus  @default(REQUESTED)
  reason        String
  requestedAt   DateTime      @default(now())

  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?

  // Mark changes post re-eval
  previousMarks Float?
  revisedMarks  Float?
  previousGrade String?
  revisedGrade  String?

  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([examId])
  @@index([studentId])
  @@index([status])
  @@index([examMarkId])
}

// ResultProcessingJob — Async result generation tracking
model ResultProcessingJob {
  id            String   @id @default(uuid())
  universityId  String?
  semester      String
  academicYear  String
  batchFilter   Json?    // { branch, section, subjectIds }

  status        String   @default("QUEUED") // QUEUED, PROCESSING, COMPLETED, FAILED
  totalStudents Int      @default(0)
  processed     Int      @default(0)
  failed        Int      @default(0)
  errorLog      Json?

  triggeredById String
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([universityId])
  @@index([semester, academicYear])
  @@index([status])
}

// Legacy result model (kept for backward compatibility)
model Result {
  id         String   @id @default(uuid())
  marks      Float
  grade      String
  examType   String   // e.g. "MID_TERM", "FINAL"
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}



model HostelRoom {
  id        String   @id @default(uuid())
  roomNo    String
  block     String
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model LibraryIssue {
  id         String    @id @default(uuid())
  bookTitle  String
  issueDate  DateTime  @default(now())
  returnDate DateTime?
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model FeeReceipt {
  id        String   @id @default(uuid())
  amount    Float
  status    String   // "PAID", "PENDING"
  dueDate   DateTime
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  history   Json     // Stores array of prompt/response turns
  context   String?  // Active ERP querying state details
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id           String   @id @default(uuid())
  title        String
  content      String
  type         String   // "EMAIL", "IN_APP"
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model UserSecret {
  id        String   @id @default(uuid())
  userId    String
  secretKey String
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "STUDENT_RECORD_CREATE"
  ipAddress String?
  details   Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  key        String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?

  @@index([userId])
}

model Program {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  durationYears Int      @default(4)
  departmentId  String?
  universityId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([universityId])
}

model Classroom {
  id            String           @id @default(uuid())
  building      String
  roomNo        String
  capacity      Int
  type          String           @default("Classroom") // e.g. "Classroom", "Lab", "SeminarHall"
  resources     Json?            // Array of features (e.g. Projector, AC)
  availability  Boolean          @default(true)
  universityId  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  offerings     CourseOffering[]

  @@index([universityId])
  @@index([building, roomNo])
}

model CourseOffering {
  id           String      @id @default(uuid())
  subjectId    String
  subject      Subject     @relation(fields: [subjectId], references: [id])
  facultyId    String?
  faculty      Faculty?    @relation(fields: [facultyId], references: [id])
  classroomId  String?
  classroom    Classroom?  @relation(fields: [classroomId], references: [id])
  section      String
  semester     String
  academicYear String
  maxCapacity  Int         @default(60)
  status       String      @default("Open") // e.g. "Open", "Closed", "Waitlist"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  enrollments  Enrollment[]

  @@index([subjectId])
  @@index([facultyId])
  @@index([classroomId])
}

model Enrollment {
  id         String         @id @default(uuid())
  studentId  String
  student    Student        @relation(fields: [studentId], references: [id])
  offeringId String
  offering   CourseOffering @relation(fields: [offeringId], references: [id])
  status     String         @default("ENROLLED") // e.g. "ENROLLED", "WAITLISTED", "DROPPED"
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([studentId])
  @@index([offeringId])
}

model AcademicCalendar {
  id           String   @id @default(uuid())
  title        String
  type         String   // e.g. "SemesterStart", "SemesterEnd", "Registration", "Exam", "Holiday"
  startDate    DateTime
  endDate      DateTime
  description  String?
  universityId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([universityId])
  @@index([startDate])
}
