datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  UNIVERSITY_ADMIN
  HOD
  FACULTY
  STUDENT
  ACCOUNTANT
  LIBRARIAN
  EXAM_CONTROLLER
  PLACEMENT_OFFICER
  HOSTEL_ADMIN
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  MEDICAL_LEAVE
  OFFICIAL_LEAVE
  HOLIDAY
  CANCELLED
  EXCUSED
}

model University {
  id        String    @id @default(uuid())
  name      String    @unique
  domain    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users     User[]
}

model User {
  id                        String              @id @default(uuid())
  email                     String              @unique
  passwordHash              String
  role                      Role                @default(STUDENT)
  isVerified                Boolean             @default(false)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  deletedAt                 DateTime?
  
  universityId              String?
  university                University?         @relation(fields: [universityId], references: [id], onDelete: SetNull)

  student                   Student?
  faculty                   Faculty?
  notifications             Notification[]
  sessions                  Session[]
  auditLogs                 AuditLog[]
  aiConversations           AIConversation[]
  passwordResets            PasswordReset[]
  emailVerifications        EmailVerification[]
  apiKeys                   ApiKey[]

  @@index([email])
  @@index([universityId])
}

model Student {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id])
  rollNo           String       @unique
  enrollmentNo     String?      @unique
  registrationNo   String?      @unique
  name             String
  branch           String
  semester         String
  academicYear     String
  status           String       @default("Active")
  admissionDate    DateTime     @default(now())
  category         String       @default("General")
  scholarship      String       @default("None")
  transport        Boolean      @default(false)
  photoUrl         String?
  parentName       String?
  parentContact    String?

  // Structured JSON fields for Enterprise scale and AI compatibility
  guardianDetails  Json?
  emergencyContact Json?
  medicalInfo      Json?
  nationality      String?      @default("Indian")
  address          Json?
  documents        Json?
  timeline         Json?
  analytics        Json?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  attendance       Attendance[]
  results          Result[]
  hostelRoom       HostelRoom?
  libraryIssues    LibraryIssue[]
  fees             FeeReceipt[]
  predictions      AttendancePrediction[]

  @@index([rollNo])
  @@index([enrollmentNo])
  @@index([registrationNo])
  @@index([userId])
  @@index([branch, semester])
  @@index([status])
}

model Faculty {
  id              String      @id @default(uuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  employeeId      String?     @unique
  name            String
  department      String
  designation     String      @default("Assistant Professor")
  joiningDate     DateTime    @default(now())
  qualification   String      @default("PhD")
  experienceYears Int         @default(0)
  status          String      @default("Active")
  specialty       String?     // Keep for backward compatibility
  researchArea    String?

  // Structured JSON fields for workload, leaves, research, and timelines
  officeInfo      Json?
  researchModule  Json?
  workload        Json?
  leaveManagement Json?
  performance     Json?
  documents       Json?
  timeline        Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  subjects        Subject[]
  schedules       Timetable[]
  facultyAttendance  FacultyAttendance[]
  attendanceSessions AttendanceSession[]

  @@index([userId])
  @@index([employeeId])
  @@index([department])
  @@index([status])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  credits   Int       @default(3)
  semester  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  subjects  Subject[]
}

model Subject {
  id         String      @id @default(uuid())
  code       String      @unique
  name       String
  courseId   String
  course     Course      @relation(fields: [courseId], references: [id])
  facultyId  String?
  faculty    Faculty?    @relation(fields: [facultyId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  attendance Attendance[]
  timetables Timetable[]
  attendanceSessions AttendanceSession[]
  predictions AttendancePrediction[]

  @@index([courseId])
  @@index([facultyId])
}

model Attendance {
  id           String            @id @default(uuid())
  date         DateTime
  status       AttendanceStatus  @default(PRESENT)
  studentId    String
  student      Student           @relation(fields: [studentId], references: [id])
  subjectId    String
  subject      Subject           @relation(fields: [subjectId], references: [id])
  sessionId    String?
  session      AttendanceSession? @relation(fields: [sessionId], references: [id])
  method       String            @default("Manual")
  remarks      String?
  metadata     Json?
  riskLevel    String            @default("Low")
  examEligible Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([studentId, subjectId, date])
  @@index([sessionId])
  @@index([date])
  @@index([status])
}

model AttendancePrediction {
  id                    String   @id @default(uuid())
  studentId             String
  student               Student  @relation(fields: [studentId], references: [id])
  subjectId             String
  subject               Subject  @relation(fields: [subjectId], references: [id])
  predictedAttendanceRate Float
  shortageRisk          String
  examEligible          Boolean  @default(true)
  confidenceScore       Float
  recommendations       Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([shortageRisk])
}

model AttendanceSession {
  id         String       @id @default(uuid())
  subjectId  String
  subject    Subject      @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    Faculty      @relation(fields: [facultyId], references: [id])
  section    String
  semester   String
  classroom  String?
  date       DateTime     @default(now())
  startTime  String
  endTime    String
  status     String       @default("Active")
  method     String       @default("Manual")
  qrCode     String?
  location   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  attendance Attendance[]

  @@index([subjectId])
  @@index([facultyId])
  @@index([date])
}

model FacultyAttendance {
  id           String    @id @default(uuid())
  facultyId    String
  faculty      Faculty   @relation(fields: [facultyId], references: [id])
  date         DateTime  @default(now())
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Float?
  status       String    @default("Present")
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([facultyId])
  @@index([date])
}

model Timetable {
  id         String   @id @default(uuid())
  dayOfWeek  Int      // 1 = Monday, etc.
  startTime  String   // e.g. "09:00"
  endTime    String   // e.g. "10:30"
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    Faculty  @relation(fields: [facultyId], references: [id])

  @@index([subjectId])
  @@index([facultyId])
}

model Result {
  id         String   @id @default(uuid())
  marks      Float
  grade      String
  examType   String   // e.g. "MID_TERM", "FINAL"
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model HostelRoom {
  id        String   @id @default(uuid())
  roomNo    String
  block     String
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model LibraryIssue {
  id         String    @id @default(uuid())
  bookTitle  String
  issueDate  DateTime  @default(now())
  returnDate DateTime?
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model FeeReceipt {
  id        String   @id @default(uuid())
  amount    Float
  status    String   // "PAID", "PENDING"
  dueDate   DateTime
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  history   Json     // Stores array of prompt/response turns
  context   String?  // Active ERP querying state details
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id           String   @id @default(uuid())
  title        String
  content      String
  type         String   // "EMAIL", "IN_APP"
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model UserSecret {
  id        String   @id @default(uuid())
  userId    String
  secretKey String
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "STUDENT_RECORD_CREATE"
  ipAddress String?
  details   Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  key        String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?

  @@index([userId])
}
