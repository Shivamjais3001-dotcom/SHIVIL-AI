# Application Config
PORT=5000
NODE_ENV=production

# Database Settings
# PostgreSQL Connection String used by Prisma Client
DATABASE_URL="postgresql://shivil_admin:password123@localhost:5432/shivil_db?schema=public"

# Redis cache
REDIS_URL="redis://localhost:6379"

# Security (JWT Keys)
JWT_ACCESS_SECRET="your_jwt_access_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key"

# Cloudinary Integration (for media assets)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Nodemailer Settings (SMTP Email)
NODEMAILER_HOST="smtp.mailtrap.io"
NODEMAILER_PORT=2525
NODEMAILER_USER="smtp-user"
NODEMAILER_PASS="smtp-pass"
