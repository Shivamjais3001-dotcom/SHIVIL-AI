# Docker Compose Environment Template

# PostgreSQL Service Config
POSTGRES_USER=shivil_admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=shivil_db

# Backend Database URLs (maps to db service inside Docker network)
DATABASE_URL=postgresql://shivil_admin:password123@db:5432/shivil_db?schema=public
REDIS_URL=redis://redis:6379

# Security Tokens
JWT_ACCESS_SECRET=shivil_access_key_2026_cosmic_glow_blue
JWT_REFRESH_SECRET=shivil_refresh_key_2026_cosmic_glow_purple

# Cloud Provider Keys
CLOUDINARY_CLOUD_NAME=shivil-cloud
CLOUDINARY_API_KEY=1234567890
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz

# Mailer Gateway Settings
NODEMAILER_HOST=smtp.mailtrap.io
NODEMAILER_PORT=2525
NODEMAILER_USER=smtp-user
NODEMAILER_PASS=smtp-pass

# Frontend Build Arguments
VITE_API_URL=/api
